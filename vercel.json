{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)\\.(js|mjs|css|json|webmanifest|svg|png|jpg|jpeg|webp|gif|ico|woff|woff2|ttf|otf|txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html|md)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/all",
      "destination": "/index.html"
    },
    {
      "source": "/football",
      "destination": "/index.html"
    },
    {
      "source": "/nfl",
      "destination": "/index.html"
    },
    {
      "source": "/mma",
      "destination": "/index.html"
    },
    {
      "source": "/boxing",
      "destination": "/index.html"
    },
    {
      "source": "/formula-1",
      "destination": "/index.html"
    },
    {
      "source": "/nba",
      "destination": "/index.html"
    },
    {
      "source": "/wnba",
      "destination": "/index.html"
    },
    {
      "source": "/mlb",
      "destination": "/index.html"
    },
    {
      "source": "/watch/:slug",
      "destination": "/watch.html"
    },
    {
      "source": "/recaps",
      "destination": "/recaps.html"
    },
    {
      "source": "/:category/recaps",
      "destination": "/recaps.html"
    },
    {
      "source": "/:category/recaps/test-player/:path*",
      "destination": "/test-player.html"
    }
  ]
}
