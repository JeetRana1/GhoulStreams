{
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "index.html",
        "watch.html",
        "recaps.html",
        "test-player.html",
        "Logo.svg",
        "GhoulStream-Logo.svg",
        "manifest.json",
        "sw.js"
      ]
    }
  },
  "headers": [
    {
      "source": "/(.*)\\.(js|mjs|css|json|webmanifest|svg|png|jpg|jpeg|webp|gif|ico|woff|woff2|ttf|otf|txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html|md)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index.js"
    },
    {
      "source": "/index.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/watch.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/watch/:slug",
      "destination": "/api/index.js"
    },
    {
      "source": "/manifest.json",
      "destination": "/api/index.js"
    },
    {
      "source": "/Logo.svg",
      "destination": "/api/index.js"
    },
    {
      "source": "/GhoulStream-Logo.svg",
      "destination": "/api/index.js"
    },
    {
      "source": "/sw.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/recaps",
      "destination": "/api/index.js"
    },
    {
      "source": "/formula-1/recaps",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    }
  ]
}
