{
  "functions": {
    "api/index.js": {
      "includeFiles": "**/*.{html,md,svg,png,json,webmanifest,js,css,ico,jpg,jpeg,webp,txt}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/:path*",
      "destination": "/api/index.js"
    }
  ]
}
