{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.{svg,png,jpg,jpeg,webp,gif,ico,json,webmanifest,js,mjs,css,txt}",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|mjs|css|json|webmanifest|svg|png|jpg|jpeg|webp|gif|ico|woff|woff2|ttf|otf|txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html|md)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=3600"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/all",
      "dest": "/index.html"
    },
    {
      "src": "/football",
      "dest": "/index.html"
    },
    {
      "src": "/nfl",
      "dest": "/index.html"
    },
    {
      "src": "/mma",
      "dest": "/index.html"
    },
    {
      "src": "/boxing",
      "dest": "/index.html"
    },
    {
      "src": "/formula-1",
      "dest": "/index.html"
    },
    {
      "src": "/nba",
      "dest": "/index.html"
    },
    {
      "src": "/wnba",
      "dest": "/index.html"
    },
    {
      "src": "/mlb",
      "dest": "/index.html"
    },
    {
      "src": "/cfl",
      "dest": "/index.html"
    },
    {
      "src": "/watch/([^/]+)",
      "dest": "/watch.html"
    },
    {
      "src": "/recaps",
      "dest": "/recaps.html"
    },
    {
      "src": "/([^/]+)/recaps",
      "dest": "/recaps.html"
    },
    {
      "src": "/([^/]+)/recaps/test-player/(.*)",
      "dest": "/test-player.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
